rules_version = '2';

// 4adra — Reglas de seguridad de Firestore.
//
// Decisión de arquitectura (ver docs/Decisions.md, ADR-009): Android y Web
// nunca usan el SDK cliente de Firestore. Todo acceso (lectura y escritura)
// pasa por la API HTTPS (Firebase Cloud Functions), que usa el Admin SDK y
// por lo tanto ignora estas reglas. Esta política de denegación total es la
// defensa en profundidad ante un cliente que intente saltarse la API y leer
// o escribir Firestore directamente.
//
// Si en el futuro se decide exponer lecturas directas de Firestore a los
// clientes (por ejemplo, para aprovechar listeners en tiempo real), eso
// requiere un ADR nuevo que reabra ADR-009 y diseñe reglas de autorización
// por documento (rol, membresía activa, propiedad) en lugar de esta regla
// general.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
